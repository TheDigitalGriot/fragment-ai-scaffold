[project]
name = "{{PROJECT_NAME}}-mcp"
version = "0.0.1"
description = "Local stdio MCP server for {{PROJECT_NAME}} (no-orphan stdio hygiene by default)"
requires-python = ">=3.10"
dependencies = ["mcp>=1.0.0"]

[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[tool.hatch.build.targets.wheel]
include = ["server.py", "_hygiene.py", "mcp_launcher.py"]
